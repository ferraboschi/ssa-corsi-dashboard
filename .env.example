# ============================================================================
# SSA Corsi Dashboard - Environment Variables
# ============================================================================
# Copy this file to .env for local development
# On Render: set these in Dashboard > Environment
#
# Last updated: 2026-03-19
# ============================================================================

# --- Node ---
NODE_ENV=production
PORT=3000

# --- Authentication ---
# Username and password to protect the dashboard
AUTH_USERNAME=admin
AUTH_PASSWORD=changeme
# Secret for signing session cookies (auto-generated if not set)
SESSION_SECRET=

# --- Shopify Admin API (app: SSA_NEWS) ---
# Store: sakesommelierassociation.myshopify.com
# App: Sviluppo app > SSA_NEWS > Credenziali API
# Token type: Admin API access token (never expires unless regenerated)
# Permissions: read/write products, orders, customers, metafields
SHOPIFY_STORE=sakesommelierassociation.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Airtable (base: SSA Corsi) ---
# Token: airtable.com/create/tokens > "ssa-corsi"
# Scopes: data.records:read, data.records:write
# Table: SSA_CourseConfig (stores costs, programs, phone overrides, share tokens)
AIRTABLE_API_KEY=patXXXXXXXXXXXXXX.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AIRTABLE_BASE_ID=appwCWGRd0jXOCxMA
AIRTABLE_TABLE_ID=tblnJO5Mf7EVmteRk

# --- Twilio (shared with Mamotte project) ---
# Console: twilio.com/console
# Used for: Twilio Lookup v2 (phone number verification)
# Cost: $0.005 per lookup, cached 30 days
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Sake Company Shopify Storefront API ---
# Store: sake-company.myshopify.com
# Used for: product images in course program
SAKE_COMPANY_STORE=sake-company.myshopify.com
SAKE_COMPANY_STOREFRONT_TOKEN=0ce8a134410b855b96fd6367301785cb

# --- GitHub (for CI/CD push) ---
# PAT: github.com/settings/tokens > ferraboschi
# Repo: ferraboschi/ssa-corsi-dashboard
# Expires: 2026-04-17
# GITHUB_PAT=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
